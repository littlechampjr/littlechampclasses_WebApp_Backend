{
  "name": "littlechampclasses-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "start:prod": "node dist/index.js",
    "seed": "tsx src/scripts/seed.ts",
