MONGODB_URI=mongodb://127.0.0.1:27017/littlechampclasses
JWT_SECRET=replace-with-long-random-string
PORT=4100
# Comma-separated origins (no path). www and apex are paired automatically (either URL allows both).
# FRONTEND_URL=https://littlechampjunior.vercel.app,https://www.littlechampjunior.com
FRONTEND_URL=http://localhost:3000

# OTP (SMS_PROVIDER=mock logs to console in development)
SMS_PROVIDER=mock
OTP_PEPPER=
OTP_TTL_MS=300000

# Razorpay (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
