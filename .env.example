MONGODB_URI=mongodb://127.0.0.1:27017/littlechampclasses
JWT_SECRET=replace-with-long-random-string
PORT=4100
# Comma-separated origins (no path). www and apex are paired automatically (either URL allows both).
# FRONTEND_URL=https://littlechampjunior.vercel.app,https://www.littlechampjunior.com
FRONTEND_URL=http://localhost:3000

# OTP — mock: console only. http|digicoders: DigiCoders sendhttp GET. If SMS_PROVIDER omitted but SMS_API_URL set → http.
# SMS_API_URL=base only (no ?authkey=…): http://sms.digicoders.in/api/sendhttp.php
SMS_PROVIDER=mock
SMS_API_URL=
SMS_AUTH_KEY=
SMS_SENDER=
SMS_ROUTE=
SMS_COUNTRY=91
SMS_DLT_TEMPLATE_ID=
OTP_PEPPER=
OTP_TTL_MS=300000

# Razorpay (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
